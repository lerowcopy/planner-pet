<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Base configuration: allow cleartext for development -->
    <!-- In production, change cleartextTrafficPermitted to false and use HTTPS -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
